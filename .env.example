# Beri ML Environment Configuration

# API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_VERTEX_PROJECT_ID=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=us-central1
CHERIML_API_KEY=your-cheriml-key

# Optional: Google Cloud credentials (if not using default)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Ollama (if running locally)
OLLAMA_ENDPOINT=http://localhost:11434

# Backend API
BERIML_API_URL=https://your-api.workers.dev
BERIML_API_KEY=your-api-key

# Mac Builder Configuration (only needed on Mac instances)
MAC_ID=mac-builder-1
HADP_API_URL=https://your-hadp-api.workers.dev
HADP_API_KEY=your-hadp-api-key

# Apple Developer (only needed on Mac instances)
APPLE_ID=your-apple-id@example.com
APPLE_TEAM_ID=ABCD1234EF
FASTLANE_USER=your-apple-id@example.com
FASTLANE_PASSWORD=your-app-specific-password
MATCH_PASSWORD=your-match-password

# App Store Connect API
APP_STORE_CONNECT_ISSUER_ID=your-issuer-id
APP_STORE_CONNECT_KEY_ID=your-key-id
APP_STORE_CONNECT_KEY_PATH=/path/to/AuthKey.p8

# Database
DATABASE_URL=your-database-url

# Redis
REDIS_URL=your-redis-url

# AWS (for CloudWatch, S3, etc.)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Cost Tracking
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD=100.00  # USD per day

# Feature Flags
ENABLE_OLLAMA=true
ENABLE_VOICE_MODE=false
ENABLE_GOOGLE_WORKSPACE=false

# Development
NODE_ENV=development
LOG_LEVEL=info

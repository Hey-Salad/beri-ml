# Beri ML .gitignore

# Environment files
.env
.env.local
.env.*.local
apple-config.yml

# Certificates and keys (NEVER COMMIT THESE!)
*.p12
*.mobileprovision
*.p8
*.cer
*.key
*.pem
AuthKey_*.p8

# Dependencies
node_modules/
bower_components/

# Build outputs
out/
dist/
build/
*.vsix

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Xcode (for Mac builds)
DerivedData/
*.xcworkspace
!*.xcworkspace/contents.xcworkspacedata
*.xcodeproj
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
*.xcuserdatad
*.moved-aside
*.mode1v3
*.mode2v3
*.perspectivev3

# Build artifacts
*.ipa
*.app
*.dSYM.zip
*.dSYM
artifacts/

# CocoaPods
ios/Pods/
Pods/
*.lock

# React Native
.expo/
.expo-shared/

# Testing
coverage/
.nyc_output/

# Database
*.db
*.sqlite
*.sqlite3

# Secrets
secrets/
.secrets/
